# Most users only need to edit 3 fields:
# - DOC_TRANS_BASE_URL
# - DOC_TRANS_API_KEY
# - DOC_TRANS_MODEL
#
# Usage:
# 1. Copy this file as .env
# 2. Fill in your own service address, key, and model
# 3. Keep the other values unchanged unless you know why you are changing them
#
# The packaged Windows app reads .env from the same folder as DocTranslationTool.exe.

DOC_TRANS_PROVIDER=openai_compatible
DOC_TRANS_API_FORMAT=openai
# Supported API formats:
# - openai
# - anthropic
DOC_TRANS_ANTHROPIC_VERSION=2023-06-01

# Base URL of your LLM service. Example:
# DOC_TRANS_BASE_URL=http://192.168.201.78:7001/v1/
DOC_TRANS_BASE_URL=https://example.internal/api/v1

# API key used by the service
DOC_TRANS_API_KEY=your_api_key_here

# Model name. Examples:
# - auto
# - qwen3-max-2026-01-23
DOC_TRANS_MODEL=internal-translate-model

# Advanced tuning. Most users can keep these defaults.
DOC_TRANS_TIMEOUT=60
DOC_TRANS_CONNECT_TIMEOUT=10
DOC_TRANS_READ_TIMEOUT=60
DOC_TRANS_MAX_RETRIES=2
DOC_TRANS_BATCH_SIZE=8
DOC_TRANS_PARALLEL_BATCHES=2
DOC_TRANS_TEMPERATURE=0.2

# Optional. Comma-separated front matter fields allowed to translate.
DOC_TRANS_FRONT_MATTER_FIELDS=title,subtitle,desc
