# Most users only need to edit 3 fields:
# - DOC_TRANS_BASE_URL
# - DOC_TRANS_API_KEY
# - DOC_TRANS_MODEL
#
# Config file relationship:
# - .env is the main runtime config for most users
# - settings.json is optional advanced config
# - if the same field exists in both .env and settings.json, .env wins
# - glossary.json is loaded automatically for terminology pairs
# - settings.example.json and glossary.example.json are templates only
#
# Usage:
# 1. Copy this file as .env
# 2. Fill in your own service address, key, and model
# 3. Keep the other values unchanged unless you know why you are changing them
#
# The packaged Windows app reads .env from the same folder as DocTranslationTool.exe.

DOC_TRANS_PROVIDER=openai_compatible
DOC_TRANS_API_FORMAT=openai
# Supported API formats:
# - openai
# - anthropic
# If your service is Anthropic-compatible:
# - set DOC_TRANS_API_FORMAT=anthropic
# - keep DOC_TRANS_ANTHROPIC_VERSION as default unless your provider says otherwise
# - set DOC_TRANS_BASE_URL to the service root
# - do not manually append /messages
DOC_TRANS_ANTHROPIC_VERSION=2023-06-01

# Base URL of your LLM service. Example:
# DOC_TRANS_BASE_URL=http://192.168.201.78:7001/v1/
DOC_TRANS_BASE_URL=https://example.internal/api/v1

# API key used by the service
DOC_TRANS_API_KEY=your_api_key_here

# Model name. Examples:
# - auto
# - qwen3-max-2026-01-23
DOC_TRANS_MODEL=internal-translate-model

# Advanced tuning. Most users can keep these defaults.
DOC_TRANS_TIMEOUT=60
DOC_TRANS_CONNECT_TIMEOUT=10
DOC_TRANS_READ_TIMEOUT=60
DOC_TRANS_MAX_RETRIES=2
DOC_TRANS_BATCH_SIZE=8
DOC_TRANS_PARALLEL_BATCHES=2
DOC_TRANS_TEMPERATURE=0.2
# Optional. Leave commented out unless your provider requires an explicit output cap.
# DOC_TRANS_MAX_TOKENS=4096

# Validation settings (optional, for technical documents)
# validation_mode: strict, balanced (default), lenient
# - strict: original behavior, strict validation (threshold=3)
# - balanced: relaxed for technical docs (threshold=10)
# - lenient: very relaxed for code-heavy docs (threshold=15)
DOC_TRANS_VALIDATION_MODE=balanced
# Threshold for detecting residual language (number of lowercase English words allowed)
# Technical documents often contain many English terms that should not be translated
DOC_TRANS_RESIDUAL_LANGUAGE_THRESHOLD=10
# Allow placeholder reordering in translation (true/false)
# Set to true to allow natural language word order adjustments
DOC_TRANS_ALLOW_PLACEHOLDER_REORDER=true
# Minimum batch size before splitting (1-10)
# Larger values preserve context better but may fail more often
DOC_TRANS_MIN_BATCH_SPLIT_SIZE=3

# Optional. Comma-separated front matter fields allowed to translate.
DOC_TRANS_FRONT_MATTER_FIELDS=title,subtitle,desc
